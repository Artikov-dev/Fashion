# ──────────────────────────────────────────────────────────────────
# Nexora CRM — Backend Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────

FLASK_ENV=development
FLASK_CONFIG=development
FLASK_APP=app.py

# Security keys — CHANGE in production (min 32 characters)
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
JWT_SECRET_KEY=replace-with-another-long-random-string-at-least-32-chars

# PostgreSQL (Docker local)
DATABASE_URL=postgresql://nexora:nexora_secret@localhost:5432/nexora_crm

# PostgreSQL (Render / Railway / Supabase example)
# DATABASE_URL=postgresql://username:password@host:5432/nexora_crm

PORT=5000
