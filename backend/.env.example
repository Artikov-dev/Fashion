# ──────────────────────────────────────────────────────────────────
# Fashion E-Commerce System — Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────

# Flask environment (development | production | testing)
FLASK_ENV=development
FLASK_CONFIG=development
FLASK_APP=app.py

# Security keys — CHANGE THESE in production (min 32 characters)
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
JWT_SECRET_KEY=replace-with-another-long-random-string-at-least-32-chars

# Database — leave commented out for local SQLite
# Uncomment and set for PostgreSQL (Supabase, Render, Railway, etc.)
# DATABASE_URL=postgresql://username:password@host:5432/fashion_shop

# Server port
PORT=5000

# Optional: CORS origin (if deploying frontend separately)
# FRONTEND_URL=https://your-frontend.vercel.app
